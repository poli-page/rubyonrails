# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database (if any leaks in).
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids/.keep
!/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
# (Committed for this demo app so anyone can clone-and-boot — drop this
# comment + uncomment the line below in a real production app.)
# /config/master.key

# Ignore local environment overrides.
/.env
/.env.local
/.env*.local

# Storage and uploaded files.
/storage/*
!/storage/.keep
